# ─────────────────────────────────────────────
# LEX — Variáveis de ambiente do back-end
# ─────────────────────────────────────────────
# Copie para .env e preencha os valores reais.
# Nunca commite o .env real no GitHub.

# ── Aplicação ────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=troque-por-uma-chave-segura-de-64-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Banco de dados (MySQL/XAMPP) ─────────────
DATABASE_URL=mysql+pymysql://root:@localhost:3306/lex_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE_SECONDS=300
DB_POOL_PRE_PING=true

# ── API Escavador ────────────────────────────
ESCAVADOR_API_KEY=sua-chave-aqui
ESCAVADOR_BASE_URL=https://api.escavador.com/api/v2

# ── CORS (front-end) ─────────────────────────
# Aceita uma URL ou várias separadas por vírgula
FRONT_URL=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ─────────────────────────────
# Formato SlowAPI: "N/period" (minute | hour | day)
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
