# ─────────────────────────────────────────────
# LEX — Variáveis de ambiente do back-end
# ─────────────────────────────────────────────
# Copie para .env e preencha os valores reais.
# Nunca commite o .env real no GitHub.

# ── Aplicação ────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=CHANGE_ME_WITH_A_STRONG_RANDOM_SECRET_MIN_48_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Banco de dados (MySQL/XAMPP) ─────────────
DATABASE_URL=mysql+pymysql://root:@localhost:3306/lex_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE_SECONDS=300
DB_POOL_PRE_PING=true

# ── API Escavador ────────────────────────────
ESCAVADOR_API_KEY=sua-chave-aqui
ESCAVADOR_BASE_URL=https://api.escavador.com/api/v2

# ── E-mail transacional (Brevo) ──────────────
BREVO_API_KEY=sua-chave-brevo-aqui
BREVO_SENDER_EMAIL=no-reply@seu-dominio.com
BREVO_SENDER_NAME=Lex
FRONT_RESET_PASSWORD_URL=http://localhost:3000/redefinir-senha
PASSWORD_RESET_TOKEN_TTL_MINUTES=15

# ── CORS (front-end) ─────────────────────────
# Aceita uma URL ou várias separadas por vírgula
FRONT_URL=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ─────────────────────────────
# Formato SlowAPI: "N/period" (minute | hour | day)
RATE_LIMIT_LOGIN=6/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_FORGOT_PASSWORD=3/minute
RATE_LIMIT_RESET_PASSWORD=5/minute
